# Dependencies
node_modules/

# Build artifacts
# Fork divergence: upstream gitignores dist/ and relies on a CI workflow
# (.github/workflows/build-dist.yml) to rebuild and commit it post-merge.
# This fork ships dist/ manually on each release so users installing from the
# fork get working compiled output without needing the CI step. Keeping dist/
# tracked here means `git add` works normally and we stop hitting the
# "paths are ignored" warning when committing rebuilt artefacts.
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed
*.fifo

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Environment/secrets (safety)
.env
.env.*
.claude/settings.json
.claude/*.local.json
*.pem
*.key
secrets/
credentials/

# Test coverage
coverage/
.nyc_output/

# Temp files
tmp/
temp/
*.tmp

# Lock files (keep package-lock.json for npm)
yarn.lock
bun.lock

# Local dev-install config (written when symlinked into ~/.claude/plugins)
config.json

# Local dev-run caches
.usage-cache.json
config-cache/
transcript-cache/
